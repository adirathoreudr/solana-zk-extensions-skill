# Copy this file to `.env` and fill in real values. `.env` is gitignored — `.env.example` is not.

# --- Required ---

# Helius API key (free tier OK). Used by zk_compression.md and
# agents/python_ts_client_agent.md to build the Helius RPC URL, which serves
# both standard Solana RPC and the Photon Indexer (ZK Compression) endpoints.
# Get one at: https://dashboard.helius.dev/api-keys
HELIUS_API_KEY=

# --- Optional ---

# devnet | mainnet-beta — switches which Helius RPC host the examples build.
# Defaults to devnet in all sample code in this repo if unset.
SOLANA_CLUSTER=devnet

# Path to the local keypair used as fee payer / signer in scripts and by
# `anchor test` / `anchor deploy`. Defaults to ~/.config/solana/id.json if unset.
ANCHOR_WALLET=~/.config/solana/id.json

# Deployed program ID for the zk_loyalty Anchor program (skill/zk_compression.md
# + skill/transfer_hooks.md). Fill in after your first `anchor deploy`.
PROGRAM_ID=

# Fine-grained GitHub PAT (Contents: Read and write, repo-scoped, 90-day
# expiry — see README). NOT read by any script in this repo today; only add
# this if you wire up a GitHub Action (e.g. auto-publish the skill) that
# needs to push commits or create releases on your behalf.
# GITHUB_TOKEN=
